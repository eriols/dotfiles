#!/bin/sh
set -e
PATH="/usr/local/bin:$PATH"
dir="$(git rev-parse --git-dir)"

# ctags: definitions incl. enum members / typedefs / macros.
# cscope's find-definition search does not report enumerators, so vim falls
# back to this tags file for them (set tags+=.git/tags, csto=0).
trap 'rm -f "$dir/$$.tags"' EXIT
git ls-files | \
    ctags --tag-relative=yes -L - -f"$dir/$$.tags" --languages=-javascript,sql
mv "$dir/$$.tags" "$dir/tags"

# cscope: functions, symbols, callers/callees.
if command -v cscope >/dev/null 2>&1; then
    rm -f cscope.files cscope.out cscope.in.out cscope.po.out
    git ls-files -- '*.[ch]' '*.java' '*.py' '*.cpp' > cscope.files
    cscope -b -q -k
fi
